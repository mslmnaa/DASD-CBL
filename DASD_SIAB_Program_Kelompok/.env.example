# Salin file ini menjadi .env lalu isi nilai sebenarnya.
# JANGAN commit file .env ke repository (sudah masuk .gitignore).

# Kunci rahasia Flask (buat acak, mis. python -c "import secrets;print(secrets.token_hex(32))")
SECRET_KEY=ganti-dengan-kunci-acak-panjang

# Mode (production / development)
FLASK_ENV=production
